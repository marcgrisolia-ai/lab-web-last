# CMS (Directus) configuration
VITE_CMS_PROVIDER=directus
VITE_CMS_URL=https://your-directus-instance.example
VITE_CMS_TOKEN=your_api_token
VITE_CMS_CACHE_TTL_MS=300000

# Optional API backend for a custom admin server.
# Leave empty for GitHub Pages static mode.
VITE_API_BASE=

# Admin editor (SE Member UI)
# Leave empty for GitHub Pages static mode with local drafts + tests.json download.
VITE_ADMIN_API_KEY=
VITE_ADMIN_API_BASE=
