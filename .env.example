# CMS (Directus) configuration
# Do not put private tokens in VITE_* variables. They are embedded in the browser bundle.
VITE_CMS_PROVIDER=directus
VITE_CMS_URL=https://your-directus-instance.example
VITE_CMS_TOKEN=
VITE_CMS_CACHE_TTL_MS=300000

# Optional local-only API backend for development.
# Leave empty for GitHub Pages static mode.
VITE_API_BASE=
VITE_ENABLE_LOCAL_ADMIN_API=false

# Admin editor (SE Member UI). Local development only when VITE_ENABLE_LOCAL_ADMIN_API=true.
# Leave empty for GitHub Pages static mode with local drafts + tests.json download.
VITE_ADMIN_API_KEY=
VITE_ADMIN_API_BASE=
