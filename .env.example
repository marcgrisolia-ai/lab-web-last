# CMS (Directus) configuration
VITE_CMS_PROVIDER=directus
VITE_CMS_URL=https://your-directus-instance.example
VITE_CMS_TOKEN=your_api_token
VITE_CMS_CACHE_TTL_MS=300000

# API backend
VITE_API_BASE=http://127.0.0.1:8000

# Admin editor (SE Member UI)
# Optional. Leave empty for static GitHub/Netlify mode with local drafts + tests.json download.
# Set this only when a server-side admin endpoint is configured.
VITE_ADMIN_API_KEY=change-me
VITE_ADMIN_API_BASE=/.netlify/functions/admin-tests

# Server-only Netlify function variables. Configure these in Netlify, not in Vite/client env.
# ADMIN_API_KEY must match VITE_ADMIN_API_KEY.
ADMIN_API_KEY=change-me
GITHUB_TOKEN=github_pat_or_fine_grained_token
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main
GITHUB_CONTENT_PATH=public/data/tests.json
ALLOWED_ORIGIN=https://your-site.netlify.app
